# Cloud Supabase credentials for the data migration runbook (docs/06_data_migration.md).
#
# Copy this file to .env.cloud (which is gitignored) and fill in the real values.
# Used only by your dev workstation when running the migration heredocs — the
# values are forwarded over SSH to the VM and never written to its disk.

# The xyzabcdefghij portion of your project URL https://<ref>.supabase.co
# Settings → Database → "Reference ID"
CLOUD_PROJECT_REF=

# Settings → Database → "Database password" (or click Reset to generate a fresh one)
CLOUD_DB_PASSWORD=

# Optional: space-separated list of non-public schemas to include in the dump.
# Leave empty unless you've added schemas like "reporting" or "analytics" on cloud.
EXTRA_SCHEMAS=

# Optional: space-separated list of representative tables for the row-count
# verification step. Pick 3–5 of your largest user-data tables.
TABLES="public.profiles public.orders auth.users"
