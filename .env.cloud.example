# Cloud Supabase credentials for the data migration runbooks
# (docs/06_data_migration.md and docs/07_storage_sync.md).
#
# Copy this file to .env.cloud (which is gitignored) and fill in the real values.
# Used on whichever machine runs the dump/sync commands.

# Cloud project ref — the xyzabc part of https://xyzabc.supabase.co
CLOUD_PROJECT_REF=

# Cloud service-role key — required for storage sync (pssh-2iy).
# Where to get it:
#   Supabase dashboard → Settings → API → "Project API keys" → "service_role" (the SECRET one)
# Format will be either:
#   * sb_secret_xxx... (newer projects)
#   * eyJhbGciOiJIUzI1NiI... (older JWT-format projects)
# Both work as a Bearer token against the storage REST API.
# This is an ADMIN token — it bypasses RLS and can read/write all buckets.
# Keep it in .env.cloud (gitignored), never commit.
CLOUD_SERVICE_ROLE_KEY=

# Full Postgres connection string for the cloud Supabase project.
#
# Where to get it:
#   Supabase dashboard → Settings → Database → Connection string → URI tab
#
# Two flavours; pick based on what kind of routing the machine running pg_dump has:
#
#   * "Direct connection"  — IPv6-only, FREE. Use this if the machine has IPv6
#                            (most UK mobile networks; many home ISPs; cloud VMs).
#                            Hostname: db.<project-ref>.supabase.co
#   * "Session pooler"     — IPv4, requires Supabase IPv4 add-on (~$4/mo).
#                            Hostname: aws-0-<region>.pooler.supabase.com
#                            NOTE: NOT the "Transaction pooler" (port 6543) — that
#                            one breaks pg_dump because it doesn't preserve session state.
#
# Either way, replace [YOUR-PASSWORD] in the copied URI with your actual database
# password (Settings → Database → "Database password").
CLOUD_DB_URL=

# Optional: space-separated list of non-public schemas to include in the dump.
# Leave empty unless you've added schemas like "reporting" or "analytics" on cloud.
EXTRA_SCHEMAS=

# Optional: space-separated list of representative tables for the row-count
# verification step. Pick 3–5 of your largest user-data tables.
TABLES="public.profiles public.orders auth.users"
