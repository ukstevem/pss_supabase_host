# Supabase self-hosted secrets — placeholder template.
#
# Real values live in /opt/pss-supabase-host/.env on the VM (mode 600,
# never committed). Generate them with scripts/gen_secrets.py — see
# docs/04_secrets.md for the full procedure and rotation rules.
#
# This file documents the SHAPE of the env file the rest of the runbook
# expects. Don't fill in real values here.

# ---- Identity / signing ----
# 64-char URL-safe alphanumeric. Rotation forces a rebuild of every PSS
# standalone app (because NEXT_PUBLIC_SUPABASE_ANON_KEY is baked at build
# time, not runtime — see docs/SKILL_pss_standalone_app.md).
JWT_SECRET=

# Derived from JWT_SECRET via HS256. 10-year expiry.
# - ANON_KEY: client-side, role=anon (RLS-gated reads/writes)
# - SERVICE_ROLE_KEY: server-side only, bypasses RLS — TREAT AS SECRET
ANON_KEY=
SERVICE_ROLE_KEY=

# ---- Database ----
# Postgres superuser password. 32-char URL-safe alphanumeric.
POSTGRES_PASSWORD=

# ---- Studio dashboard (Supabase admin UI auth) ----
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=
