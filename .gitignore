
# Beads / Dolt files (added by bd init)
.dolt/
*.db
.beads-credential-key

# Local secrets — only *.env.example templates are committed.
# Real .env lives on the VM at /opt/pss-supabase-host/.env (mode 600).
# Per-machine .env.cloud (and similar) are local only.
.env
.env.*
!.env.example
!.env.*.example
